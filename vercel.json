{
  "version": 2,
  "buildCommand": "cd artifacts/jg-youth && node ../../node_modules/.pnpm/vite@7.3.2_@types+node@25.3_d5269a53d302b42e602832b0eaecec0c/node_modules/vite/bin/vite.js build --config vite.config.ts",
  "outputDirectory": "artifacts/jg-youth/dist/public",
  "installCommand": "pnpm install --ignore-scripts --no-frozen-lockfile --shamefully-hoist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://youth-connect-production.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
