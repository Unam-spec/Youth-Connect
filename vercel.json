{
  "version": 2,
  "buildCommand": "cd artifacts/jg-youth && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "artifacts/jg-youth/dist/public",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://youth-connect-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
