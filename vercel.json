{
  "version": 2,
  "installCommand": "npm install --prefix artifacts/jg-youth --legacy-peer-deps --include=dev",
  "buildCommand": "cd artifacts/jg-youth && npx --no-install vite build --config vite.config.ts",
  "outputDirectory": "artifacts/jg-youth/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://youth-connect-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
