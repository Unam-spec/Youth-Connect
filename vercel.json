{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/jg-youth exec vite build --config vite.config.ts",
  "outputDirectory": "artifacts/jg-youth/dist/public",
  "installCommand": "pnpm install --ignore-scripts --no-frozen-lockfile",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://youth-connect-production.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
