{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "pnpm --filter=@workspace/api-server run start",
    "dev": "concurrently \"pnpm --filter=@workspace/api-server dev\" \"pnpm --filter=@workspace/jg-youth dev\"",
    "build": "pnpm run typecheck && pnpm --recursive --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm --recursive --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "prettier": "^3.8.1",
    "vite": "^7.3.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@tailwindcss/vite": "^4.1.14",
    "tailwindcss": "^4.1.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/node": "^25.3.3",
    "@sentry/react": "^8.0.0",
    "@sentry/node": "^8.0.0"
  },
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "@clerk/shared"
    ]
  }
}
